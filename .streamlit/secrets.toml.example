# Copy this file to .streamlit/secrets.toml and fill in real values.
# Never commit .streamlit/secrets.toml.
# The app treats placeholder values as not configured and will stay in demo mode.

[auth]
# Local development callback. Change this for deployed apps.
redirect_uri = "http://localhost:8501/oauth2callback"
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
cookie_secret = "replace-with-a-long-random-secret"
client_id = "replace-with-your-google-client-id.apps.googleusercontent.com"
client_secret = "replace-with-your-google-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[app]
# First trusted admin account. This user is promoted to admin whenever the app starts.
bootstrap_admin_email = "director@example.com"
