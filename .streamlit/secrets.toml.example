# Copy this file to .streamlit/secrets.toml for local development.
# Do not commit real secrets.

[auth]
# For local development with the default Streamlit port:
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-a-long-random-string"
client_id = "replace-with-google-oauth-client-id"
client_secret = "replace-with-google-oauth-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[app]
# Users in this list become admins automatically when they log in.
admin_emails = ["admin@example.com"]
